{
  "manifest_version": 3,
  "name": "Shopee AI 描述生成器 (30功能版)",
  "version": "2.4.0",
  "description": "為 Shopee 賣家提供 30 種 AI 智能描述生成功能，支援批量、監控、搬家、多語言、SEO、利潤分析、Pro 功能等。完整實現所有 Phase。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms",
    "notifications",
    "downloads",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://shopee.tw/*",
    "https://*.shopee.tw/*",
    "https://shopee.com/*",
    "https://*.shopee.com/*",
    "https://shopee.sg/*",
    "https://*.shopee.sg/*",
    "https://shopee.my/*",
    "https://*.shopee.my/*",
    "https://shopee.ph/*",
    "https://*.shopee.ph/*",
    "https://shopee.vn/*",
    "https://*.shopee.vn/*",
    "https://shopee.co.id/*",
    "https://*.shopee.co.id/*",
    "https://shopee.co.th/*",
    "https://*.shopee.co.th/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shopee.tw/*",
        "https://*.shopee.tw/*",
        "https://shopee.com/*",
        "https://*.shopee.com/*",
        "https://shopee.sg/*",
        "https://*.shopee.sg/*",
        "https://shopee.my/*",
        "https://*.shopee.my/*",
        "https://shopee.ph/*",
        "https://*.shopee.ph/*",
        "https://shopee.vn/*",
        "https://*.shopee.vn/*",
        "https://shopee.co.id/*",
        "https://*.shopee.co.id/*",
        "https://shopee.co.th/*",
        "https://*.shopee.co.th/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Open Shopee AI Generator"
    }
  }
}

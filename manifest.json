{
  "manifest_version": 3,
  "name": "Shopee AI 描述生成器 (30功能版)",
  "version": "1.0.0",
  "description": "為 Shopee 賣家提供 30 種 AI 智能描述生成功能，支援多語言、SEO 優化、A/B 測試等。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://shopee.tw/*",
    "https://shopee.com/*",
    "https://*.shopee.*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shopee.tw/*",
        "https://shopee.com/*",
        "https://*.shopee.*/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
